{
  "name": "payloadcms-openai-textgen",
  "version": "0.1.0",
  "description": "AI text generation plugin for Payload CMS using OpenAI",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/exports/client.js",
      "types": "./dist/exports/client.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:swc && pnpm build:types",
    "build:swc": "swc src -d dist --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "swc src -d dist --strip-leading-paths --watch"
  },
  "dependencies": {
    "openai": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.0",
    "@types/react": "^19.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "openai",
    "ai",
    "text-generation",
    "lexical"
  ]
}
